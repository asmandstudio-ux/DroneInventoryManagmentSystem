# Copy to "release/.env" and edit values before running the release bundle.
#
# Required (security)
JWT_SECRET_KEY=0lSVwHi9v4ZDMxa2e0pjXXqM_63Y3DYaSw3EgPZB4Hgl5fqR6_LrlS7_qs7rZW1C
POSTGRES_PASSWORD=apLXxByA78MVBX2zf7zXe6HKmKMYD0-L
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=RRUlBALP4mnUuHheDqC20hW-F6N2hJ2b

# Required (images) - set to the release artifact tags you ship (registry tag or local tag after docker load).
BACKEND_IMAGE=droneims-backend:1.0.0
DASHBOARD_IMAGE=droneims-dashboard:1.0.0
# Optional: if you publish a separate worker image (otherwise BACKEND_IMAGE is reused)
# WORKER_IMAGE=droneims-worker:1.0.0

# Ports (host bindings; default binds to localhost only)
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# App/runtime
ENV=prod
UVICORN_WORKERS=2
CORS_ORIGINS=http://localhost:3000

# Database overrides (normally not needed; compose builds DATABASE_URL from POSTGRES_* if unset)
POSTGRES_DB=droneims
POSTGRES_USER=postgres
# DATABASE_URL=postgresql+asyncpg://postgres:CHANGE-ME@postgres:5432/droneims

# S3/MinIO
S3_BUCKET=droneims
S3_REGION=us-east-1
S3_PRESIGN_EXPIRES_SECONDS=900
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY_ID=CHANGE-ME
# S3_SECRET_ACCESS_KEY=CHANGE-ME

# Frontend (client-side API base URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Background jobs (default inline for release bundle simplicity)
REPORT_JOBS_INLINE=true
SCAN_JOBS_INLINE=true
SCAN_JOBS_AUTO_ENQUEUE=true
