APP_NAME=DroneInventoryManagmentSystem API
ENV=dev
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (Async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/droneims

# S3/MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=droneims
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PRESIGN_EXPIRES_SECONDS=900

# docker-compose (MinIO)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# docker-compose (Postgres)
POSTGRES_DB=droneims
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Background jobs
REPORT_JOBS_INLINE=false
SCAN_JOBS_INLINE=false
SCAN_JOBS_AUTO_ENQUEUE=true

# Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
